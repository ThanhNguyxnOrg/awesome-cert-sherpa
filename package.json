{
  "name": "awesome-cert-sherpa",
  "version": "0.1.0",
  "private": true,
  "description": "Community-driven certification exam prep hub (awesome-style + practice engine).",
  "scripts": {
    "dev": "pnpm --filter website start",
    "build": "pnpm build:bank && pnpm --filter website build",
    "build:bank": "tsx tools/build-bank.ts",
    "serve": "pnpm --filter website serve",
    "clear": "pnpm --filter website clear",
    "typecheck": "pnpm --filter website typecheck",
    "validate:bank": "tsx tools/validate-bank.ts"
  },
  "engines": {
    "node": ">=20.0"
  },
  "packageManager": "pnpm@10.28.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThanhNguyxn/awesome-cert-sherpa.git"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fast-glob": "^3.3.3",
    "tsx": "^4.21.0",
    "yaml": "^2.8.2"
  }
}
